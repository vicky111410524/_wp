<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Posts - Threads</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; background: #000; color: #fff; min-height: 100vh; }
    a { text-decoration: none; color: inherit; }
    
    .container { display: flex; max-width: 1200px; margin: 0 auto; }
    
    .sidebar { width: 275px; padding: 20px; position: fixed; height: 100vh; border-right: 1px solid #2e2e2e; }
    .logo { font-size: 28px; font-weight: 700; padding: 15px; margin-bottom: 20px; }
    .logo span { color: #ff4444; }
    
    .nav-item { display: flex; align-items: center; padding: 15px; font-size: 18px; border-radius: 30px; margin: 5px 0; transition: background 0.2s; }
    .nav-item:hover { background: #1a1a1a; }
    .nav-item.active { font-weight: 700; }
    .nav-item svg { margin-right: 15px; }
    
    .main { flex: 1; margin-left: 275px; max-width: none; border-right: 1px solid #2e2e2e; min-height: 100vh; }
    .header-title { font-size: 24px; font-weight: 700; padding: 15px 20px; border-bottom: 1px solid #2e2e2e; }
    
    .post-box { padding: 20px; border-bottom: 1px solid #2e2e2e; }
    .post-box-top { display: flex; gap: 15px; }
    .avatar { width: 48px; height: 48px; border-radius: 50%; background: linear-gradient(135deg, #ff4444, #ff8844); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 20px; }
    .post-input { flex: 1; background: transparent; border: none; color: #fff; font-size: 18px; outline: none; resize: none; }
    .post-input::placeholder { color: #666; }
    .post-actions { display: flex; justify-content: space-between; align-items: center; margin-top: 15px; padding-top: 15px; border-top: 1px solid #2e2e2e; }
    .btn { padding: 10px 25px; background: #ff4444; color: #fff; border: none; border-radius: 25px; font-weight: 600; cursor: pointer; }
    .btn:hover { opacity: 0.8; }
    
    .post { padding: 15px 20px; border-bottom: 1px solid #2e2e2e; }
    .post:hover { background: #0a0a0a; }
    .post-header { display: flex; gap: 12px; margin-bottom: 10px; cursor: pointer; }
    .post-avatar { width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, #ff4444, #ff8844); display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 16px; }
    .post-user { font-weight: 600; }
    .post-time { color: #666; font-size: 14px; }
    .post-content { font-size: 16px; line-height: 1.5; margin-left: 52px; white-space: pre-wrap; }
    .post-actions-row { display: flex; gap: 20px; margin-left: 52px; margin-top: 10px; }
    .delete-btn { background: transparent; border: 1px solid #ff4444; color: #ff4444; padding: 5px 15px; border-radius: 15px; cursor: pointer; }
    .delete-btn:hover { background: #ff4444; color: #fff; }
    
    .right-panel { flex: 1; padding: 20px; max-width: 350px; }
    .logout-btn { display: block; padding: 15px; background: #161616; color: #fff; text-align: center; border-radius: 30px; font-weight: 600; margin: 10px 0; }
    
    @media (max-width: 1000px) {
      .right-panel { display: none; }
    }
    @media (max-width: 700px) {
      .sidebar { width: 80px; padding: 10px; }
      .nav-item span { display: none; }
      .logo { padding: 10px; }
      .main { margin-left: 80px; }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="sidebar">
      <a href="/" class="logo">Thre<span>ads</span></a>
      
      <a href="/for-you" class="nav-item">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M21 8.719L7.836 14.303C7.405 14.768 7 15.299 7 16h3c0 1.048-.405 2.088-1.145 2.859l4.154 3.364c.738-.741 1.191-1.645 1.191-2.723v-.364L21 8.719z"/></svg>
        <span>For You</span>
      </a>
      
      <% if (user) { %>
      <a href="/my-posts" class="nav-item active">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M5 21h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2zm0-17h14v14H5V4z"/></svg>
        <span>My Posts</span>
      </a>
      
      <a href="/logout" class="nav-item"><span>Logout</span></a>
      <% } else { %>
      <a href="/login" class="nav-item"><span>Login</span></a>
      <% } %>
    </div>
    
    <div class="main">
      <div class="header-title">My Posts</div>
      
      <div class="post-box">
        <div class="post-box-top">
          <div class="avatar"><%= user ? user.username.charAt(0).toUpperCase() : '' %></div>
          <textarea class="post-input" id="postContent" placeholder="What is happening?!" rows="3"></textarea>
        </div>
        <div class="post-actions">
          <div></div>
          <button class="btn" onclick="submitPost()">Post</button>
        </div>
      </div>
      
      <% posts.forEach(post => { %>
      <a href="/user/<%= post.username %>" class="post">
        <div class="post-header">
          <div class="post-avatar"><%= post.username.charAt(0).toUpperCase() %></div>
          <div>
            <div class="post-user"><%= post.username %></div>
            <div class="post-time"><%= new Date(post.created_at).toLocaleString() %></div>
          </div>
        </div>
        <div class="post-content"><%= post.content %></div>
      </a>
      <% }); %>
      
      <% if (posts.length === 0) { %>
      <div class="post" style="text-align: center; color: #666;">No posts yet. Start posting!</div>
      <% } %>
    </div>
    
    <div class="right-panel">
      <a href="/logout" class="logout-btn">Logout</a>
    </div>
  </div>
  
  <script>
    function submitPost() {
      const content = document.getElementById('postContent').value.trim();
      if (!content) return;
      
      fetch('/new', {
        method: 'POST',
        headers: {'Content-Type': 'application/x-www-form-urlencoded'},
        body: 'title=' + encodeURIComponent(content.substring(0, 50)) + '&content=' + encodeURIComponent(content)
      }).then(() => window.location.reload());
    }
  </script>
</body>
</html>