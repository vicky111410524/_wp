<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register - Threads</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; background: #000; color: #fff; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    a { text-decoration: none; color: inherit; }
    
    .login-box { width: 400px; padding: 30px; }
    .logo { font-size: 32px; font-weight: 700; text-align: center; margin-bottom: 30px; }
    .logo span { color: #ff4444; }
    
    h1 { font-size: 28px; font-weight: 700; text-align: center; margin-bottom: 20px; }
    
    input { width: 100%; padding: 15px; margin: 10px 0; background: #161616; border: 1px solid #2e2e2e; border-radius: 8px; color: #fff; font-size: 16px; outline: none; }
    input:focus { border-color: #ff4444; }
    
    .btn { width: 100%; padding: 15px; background: #ff4444; color: #fff; border: none; border-radius: 30px; font-size: 16px; font-weight: 700; cursor: pointer; margin: 20px 0; transition: opacity 0.2s; }
    .btn:hover { opacity: 0.8; }
    
    .error { color: #ff4444; text-align: center; margin: 10px 0; }
    
    .link { text-align: center; color: #666; margin-top: 20px; }
    .link a { color: #ff4444; }
  </style>
</head>
<body>
  <div class="login-box">
    <div class="logo">Thre<span>ads</span></div>
    <h1>Create account</h1>
    
    <% if (error) { %>
      <p class="error"><%= error %></p>
    <% } %>
    
    <form action="/register" method="POST">
      <input type="text" name="username" placeholder="Username" required>
      <input type="password" name="password" placeholder="Password" required>
      <button type="submit" class="btn">Sign up</button>
    </form>
    
    <p class="link">Already have an account? <a href="/login">Log in</a></p>
  </div>
</body>
</html>